;Turning - OD parallel turning
o<turning> sub

  o<backup_status> call

#<turning_x>       = #1   (finish diameter)
#<turning_ss>      = #2   (surface speed m/min)
#<turning_doc>     = #3   (depth of cut per pass mm)
#<turning_feed>    = #4   (feed mm/rev)
#<turning_z>       = #5   (finish Z position)
#<turning_radius>  = #6   (tool nose radius - reserved)
#<turning_angle>   = #7   (tool angle - reserved)
#<turning_tool>    = #8   (tool number)
#<turning_coolant> = #9   (coolant: 1=on)
#<turning_maxrpm>  = #10  (max RPM limit)

        o100 if [#<turning_tool> NE #<_current_tool>]
             (MSG,ERROR : Set tool before use macro)
        o100 return [-2]
        o100 endif

G7  ; Diameter mode
G18 ; XZ Plane
G21 ; Metric Units
G90 ; Absolute Distance

#<starting_x> = [#<_x> * 2] (starting X diameter)
#<starting_z> = #<_z>        (starting Z)

G96 D#<turning_maxrpm> S#<turning_ss>
M3
G95 F#<turning_feed>

        o110 if [#<turning_coolant>]
                M8
        o110 endif

G4 P1

(DEBUG, OD Turning: start dia=#<starting_x> finish dia=#<turning_x> start Z=#<starting_z> finish Z=#<turning_z> DOC=#<turning_doc>)

        o200 while [#<starting_x> GT [#<turning_x> + #<turning_doc>]]
             #<starting_x> = [#<starting_x> - #<turning_doc>]
             G1 X#<starting_x>
             G1 Z#<turning_z>
             G0 X[#<starting_x> + #<turning_doc>]
             G0 Z#<starting_z>
             G0 X#<starting_x>
        o200 endwhile

        G1 X#<turning_x>
        G1 Z#<turning_z>
        G0 X[#<turning_x> + #<turning_doc>]
        G0 Z#<starting_z>
        G0 X#<turning_x>  ; For touch-off

M5
M9

  o<backup_restore> call

o<turning> endsub
M2
%
